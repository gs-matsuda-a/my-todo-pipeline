# Render デプロイ用の環境変数テンプレート
# 使い方:
#   cp .env.deploy.example .env.deploy
#   # .env.deploy に実際の値を入力
#   source .env.deploy
#
# .env.deploy は .gitignore で除外済み。コミットしないこと。

# Render API キー — Render > Account Settings > API Keys で生成
RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxx

# サービス作成後（4-3 実行後）に設定
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# 4-2 で取得したオーナー ID
RENDER_OWNER_ID=usr-xxxxxxxxxxxxxxxxxxxx
